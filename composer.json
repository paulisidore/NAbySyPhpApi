{
    "name": "nabysyphpapi/xnabysygs",
    "description": "Framework de mise en place rapide d'API pour les plateformes d'application développé par PAM et MCP. (EN: Rapid API implementation framework for application platforms developed by PAM and MCP)",
    "type": "composer-plugin",
    "require": {
        "php": ">=8.1.0",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "license": "mit",
    "authors": [
        {
            "name": "Paul Isidore A. NIAMIE",
            "email": "paul.isidore@gmail.com",
            "homepage": "https://groupe-pam.net"
        }
    ],
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "NAbySy\\xNAbySyGS\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "class": "NAbySy\\xNAbySyGS\\NAbySySetup",
        "nabysygs": {
            "setup-file": "setup.html"
        }
    }
}